#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import shlex
import socket
import sys
from typing import Any


def parse_args(argv: list[str]) -> argparse.Namespace:
	parser = argparse.ArgumentParser(prog="tb")
	subparsers = parser.add_subparsers(dest="subcommand", required=True)

	exec_parser = subparsers.add_parser("exec")
	exec_parser.add_argument("--timeout", type=int, default=120)
	exec_parser.add_argument("command", nargs=argparse.REMAINDER)

	read_parser = subparsers.add_parser("read")
	read_parser.add_argument("path")

	write_parser = subparsers.add_parser("write")
	write_parser.add_argument("path")

	ls_parser = subparsers.add_parser("ls")
	ls_parser.add_argument("path")

	args = parser.parse_args(argv)
	if args.subcommand == "exec":
		command_parts = list(args.command)
		if command_parts[:1] == ["--"]:
			command_parts = command_parts[1:]
		if not command_parts:
			parser.error("tb exec requires a command after '--'")
		if len(command_parts) == 1:
			command_parts = ["bash", "-c", command_parts[0]]
		args.command_text = shlex.join(command_parts)
	return args


def get_socket_path() -> str:
	sock_path = os.environ.get("SALON_TB_BRIDGE_SOCK")
	if not sock_path:
		raise RuntimeError("SALON_TB_BRIDGE_SOCK is not set")
	return sock_path


def send_request(sock_path: str, request: dict[str, Any]) -> dict[str, Any]:
	with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as conn:
		conn.connect(sock_path)
		with conn.makefile("rwb") as stream:
			stream.write((json.dumps(request, ensure_ascii=False) + "\n").encode("utf-8"))
			stream.flush()
			response_line = stream.readline()
	if not response_line:
		raise RuntimeError("Bridge closed connection without a response")
	response = json.loads(response_line.decode("utf-8"))
	if not isinstance(response, dict):
		raise RuntimeError("Bridge returned a malformed response")
	return response


def print_response_payload(response: dict[str, Any]) -> None:
	content = response.get("content")
	output = response.get("output")
	if isinstance(content, str):
		sys.stdout.write(content)
	if isinstance(output, str):
		sys.stdout.write(output)


def main(argv: list[str] | None = None) -> int:
	args = parse_args(sys.argv[1:] if argv is None else argv)
	sock_path = get_socket_path()

	if args.subcommand == "exec":
		request = {"cmd": "exec", "args": args.command_text, "timeout": args.timeout}
	elif args.subcommand == "read":
		request = {"cmd": "read", "path": args.path}
	elif args.subcommand == "write":
		request = {"cmd": "write", "path": args.path, "content": sys.stdin.read()}
	else:
		request = {"cmd": "ls", "path": args.path}

	response = send_request(sock_path, request)
	print_response_payload(response)

	error = response.get("error")
	if isinstance(error, str) and error:
		if response.get("content") or response.get("output"):
			print(file=sys.stderr)
		print(error, file=sys.stderr)
		exit_code = response.get("exit_code")
		if isinstance(exit_code, int):
			return exit_code
		return 1

	exit_code = response.get("exit_code")
	if isinstance(exit_code, int):
		return exit_code
	return 0


if __name__ == "__main__":
	try:
		raise SystemExit(main())
	except Exception as exc:
		print(f"tb: {exc}", file=sys.stderr)
		raise SystemExit(1)
