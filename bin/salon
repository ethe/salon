#!/usr/bin/env node

import { spawnSync } from "node:child_process";
import { existsSync, realpathSync } from "node:fs";
import { createRequire } from "node:module";
import { dirname, join } from "node:path";
import { fileURLToPath, pathToFileURL } from "node:url";

const selfPath = realpathSync(fileURLToPath(import.meta.url));
const selfUrl = pathToFileURL(selfPath);
const require = createRequire(selfUrl);
const args = process.argv.slice(2);
let tsxLoaderPath;
try {
	const tsxCliPath = realpathSync(require.resolve("tsx/cli"));
	tsxLoaderPath = realpathSync(join(dirname(tsxCliPath), "loader.mjs"));
} catch {
	console.error("Error: could not resolve the 'tsx' runtime. Try reinstalling salon.");
	process.exit(1);
}

const mainPath = fileURLToPath(new URL("../src/main.ts", selfUrl));
if (!existsSync(mainPath)) {
	console.error(`Error: could not find salon entrypoint at '${mainPath}'.`);
	process.exit(1);
}

if (args[0] === "-h" || args[0] === "--help") {
	console.log("Usage: salon [workdir]");
	console.log("");
	console.log("Launch salon in the given working directory.");
	console.log("If omitted, salon uses the current directory.");
	process.exit(0);
}

const result = spawnSync(process.execPath, ["--import", tsxLoaderPath, mainPath, ...args], {
	stdio: "inherit",
});

if (result.error) {
	console.error(`Error: failed to start salon: ${result.error.message}`);
	process.exit(1);
}

if (result.signal) {
	process.kill(process.pid, result.signal);
}

process.exit(result.status ?? 1);
